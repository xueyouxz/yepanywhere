{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/dist-*",
      "!**/*.d.ts",
      "!**/.artifacts",
      "!**/.tmp",
      "!**/.handoff-recap.md",
      "!**/*.running.md",
      "!**/tasks",
      "!**/docs/tasks",
      "!**/branding",
      "!**/packages/desktop",
      "!**/packages/mobile",
      "!**/packages/server/generated/codex-app-server",
      "!**/packages/server/src/sdk/providers/codex-protocol/generated"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/device-bridge/cmd/bridge/web/**/*.html"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "warn",
        "noControlCharactersInRegex": "warn",
        "noDuplicateProperties": "warn",
        "noExplicitAny": "warn",
        "useIterableCallbackReturn": "warn"
      },
      "correctness": {
        "noInvalidUseBeforeDeclaration": "warn",
        "useExhaustiveDependencies": "warn"
      },
      "a11y": {
        "noLabelWithoutControl": "warn",
        "noStaticElementInteractions": "warn",
        "useAriaPropsForRole": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "useButtonType": "warn",
        "useHtmlLang": "warn",
        "useKeyWithClickEvents": "warn",
        "useSemanticElements": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  }
}
