{
  "name": "yep-anywhere",
  "private": true,
  "type": "module",
  "scripts": {
    "setup:core": "pnpm --filter yep-anywhere --filter @yep-anywhere/server... --filter @yep-anywhere/client... install",
    "setup-vapid": "tsx scripts/setup-vapid.ts",
    "codex:protocol:update": "node scripts/update-codex-protocol.mjs",
    "codex:protocol:check": "node scripts/update-codex-protocol.mjs --check",
    "dev": "node scripts/dev.js",
    "staging": "node scripts/staging.js",
    "dev:auto": "pnpm --filter server dev & pnpm --filter client dev",
    "dev-tailscale": "tailscale serve --bg 3400 && pnpm dev",
    "start": "NODE_ENV=production node packages/server/dist/index.js",
    "build": "pnpm -r build",
    "build:bundle": "tsx scripts/build-bundle.ts",
    "build:stable": "pnpm --filter client build:stable",
    "typecheck": "pnpm --filter shared build && pnpm -r --filter '!@yep-anywhere/mobile' exec tsc --noEmit",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter client test:e2e",
    "test:e2e:ui": "pnpm --filter client test:e2e",
    "test:e2e:android": "pnpm --filter client test:e2e:android",
    "test:e2e:android:soak": "pnpm --filter client test:e2e:android:soak",
    "test:e2e:emulator:apk": "pnpm --filter client test:e2e:emulator:apk",
    "test:e2e:emulator:apk:adaptive": "pnpm --filter client test:e2e:emulator:apk:adaptive",
    "test:e2e:chromeos": "pnpm --filter client test:e2e:chromeos",
    "test:e2e:sdk": "pnpm --filter server test:e2e",
    "test:e2e:sdk:real": "pnpm --filter server test:e2e:real",
    "test:e2e:sdk:local": "pnpm --filter server test:e2e:local",
    "test:e2e:sdk:local:quality": "pnpm --filter server test:e2e:local:quality",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "husky",
    "site:dev": "cd site && npm run dev",
    "site:build": "cd site && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "bn.js": "5.2.3"
    }
  },
  "yepAnywhere": {
    "codexCli": {
      "expectedVersion": "0.134.0"
    }
  },
  "dependencies": {
    "tssrp6a": "^3.0.0",
    "tweetnacl": "^1.0.3"
  },
  "version": "0.4.28"
}
